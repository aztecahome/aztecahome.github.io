---
import AztecaLogo from "./AztecaLogo.astro";

const pathname = new URL(Astro.request.url).pathname;
const otherPathname =
  pathname.slice(-1) === "/" ? pathname.slice(0, -1) : pathname; // remove the last "/"
const isActive = (url: string) => {
  if (url === "/") return pathname === "/" || pathname === "";
  return otherPathname === url || otherPathname.startsWith(url + "/");
};
const paths = [
  { url: "/", name: "Home", mobileCol: 1, mobileRow: 1 },
  { url: "/pest-control", name: "Pest Control", mobileCol: 1, mobileRow: 2 },
  { url: "/pools", name: "Pools", mobileCol: 2, mobileRow: 2 },
  { url: "/landscaping", name: "Landscaping", mobileCol: 3, mobileRow: 2 },
  { url: "/contact", name: "Contact", mobileCol: 3, mobileRow: 1 },
];
---

<header
  class="sticky top-[-170px] z-20 bg-[var(--nav-background)] shadow-lg md:top-0 md:flex md:justify-between"
>
  <div class="flex w-full justify-center md:justify-start">
    <a href="/">
      <AztecaLogo class="max-w-[225px]" data-turbo-permanent id="headerLogo" />
    </a>
  </div>
  <div class="md:flex md:flex-col md:justify-between">
    <div
      class="mx-3 my-1 flex h-full flex-wrap items-center justify-center md:justify-end"
    >
      <svg
        class="mx-1 h-[20px] w-[20px] shrink-0 animate-[wiggle_15s_linear_infinite_15s] fill-army-900"
        xmlns="http://www.w3.org/2000/svg"
        height="24px"
        viewBox="0 0 24 24"
        width="24px"
        fill="#000000"
      >
        <path
          d="M20.01 15.38c-1.23 0-2.42-.2-3.53-.56-.35-.12-.74-.03-1.01.24l-1.57 1.97c-2.83-1.35-5.48-3.9-6.89-6.83l1.95-1.66c.27-.28.35-.67.24-1.02-.37-1.11-.56-2.3-.56-3.53 0-.54-.45-.99-.99-.99H4.19C3.65 3 3 3.24 3 3.99 3 13.28 10.73 21 20.01 21c.71 0 .99-.63.99-1.18v-3.45c0-.54-.45-.99-.99-.99z"
        ></path>
      </svg>
      <a
        href="tel:602-926-2021"
        class="text-center text-xl font-bold text-army-900">(602)-926-2021</a
      >
    </div>
    <nav class="font-sans font-semibold text-army-900">
      <ul
        class="m-0 grid grid-cols-3 gap-1 p-1 md:flex md:auto-cols-max md:grid-flow-col-dense md:grid-cols-none md:justify-end md:gap-0 md:p-0 md:pb-0"
        role="menubar"
      >
        {
          paths.map((path) => (
            <li class="contents" role="none">
              <a
                style={`grid-column-start: ${path.mobileCol}; grid-row-start: ${path.mobileRow};`}
                class={`whitespace-nowrap rounded px-2
                        py-1.5 text-sm text-center underline transition-all ease-out hover:bg-army-400 md:m-0 md:px-3 md:py-3 md:text-base md:![grid-column-start:auto] md:![grid-row-start:auto]
                      md:rounded-none
                        md:border-b-8 md:pb-2 md:no-underline
                        md:active:pb-0 md:active:pt-4
                        ${
                          isActive(path.url)
                            ? "border-army-900 bg-army-900 text-army-50 no-underline md:bg-army-300 md:text-army-900"
                            : " border-transparent bg-army-300 md:bg-transparent "
                        }`}
                href={path.url}
                aria-current={isActive(path.url) ? "true" : "false"}
                role="menuitem"
                data-turbo-preload
              >
                {path.name}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>
<style is:global>
  :root {
    --nav-background: theme(colors.army.200);
  }

  @keyframes wiggle {
    0% {
      transform: rotate(0deg);
    }
    1.786% {
      transform: rotate(20deg);
    }
    2.679% {
      transform: rotate(-20deg);
    }
    3.571% {
      transform: rotate(20deg);
    }
    4.464% {
      transform: rotate(-20deg);
    }
    5.357% {
      transform: rotate(20deg);
    }
    7.143% {
      transform: rotate(0deg);
    }
    100% {
      transform: rotate(0deg);
    }
  }
</style>
