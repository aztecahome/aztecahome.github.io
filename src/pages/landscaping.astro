---
import Layout from "../layouts/Layout.astro";
import ButtonLink from "../components/ui/ButtonLink.astro";
import Banner from "../components/ui/Banner.astro";
import LandscapeImg from "../assets/landscape/general.webp";
import BlurryImage from "../components/ui/BlurryImage.astro";
---

<Layout title="Landscaping">
  <main>
    <section
      class="justify-top relative flex h-[75vh] flex-col items-center bg-army-900 sm:justify-center"
    >
      <div class="hero contents">
        <BlurryImage
          alt="Beautiful backyard"
          url="src/assets/landscape/general.webp"
          imageMeta={LandscapeImg}
        />
      </div>
      <div class="container absolute z-10 mx-auto flex flex-col gap-4 p-4">
        <h2
          class="max-w-[600px] rounded bg-army-50/60 p-4 text-3xl text-army-900 drop-shadow-2xl backdrop-blur-sm"
        >
          <b>Transform</b> Your Desert Landscape into a <b
            >Lush and Inviting Oasis</b
          >
        </h2>
        <ButtonLink content="Get Quote Now" url="/contact" addBorder />
      </div>
    </section>

    <Banner cta="Let's create your personal paradise" />

    <section class="my-8 bg-army-100 py-8">
      <div class="container mx-auto flex flex-col items-center">
        <h4 class="max-w-4xl p-4 text-center text-4xl font-black">
          Your Landscaping Experts
        </h4>
        <p class="accent-font max-w-prose py-4 text-2xl">
          At Azteca Home Services, we provide professional landscaping solutions
          for both residential and commercial properties. Whether you're looking
          to refresh your front yard, improve the functionality of your outdoor
          space, or completely transform your landscape, our experienced team
          delivers reliable, high-quality service tailored to your needs. From
          routine maintenance to full installations, we're here to keep your
          property looking its best.
        </p>
      </div>
    </section>

    <section class="container mx-auto p-4">
      <h4 class="py-4 text-3xl font-black uppercase">
        Landscaping Maintenance
      </h4>
      <p class="text-xl pb-4">
        Recurring services with flexible scheduling to fit your needs.
      </p>
      <ul class="grid grid-cols-1 gap-6 sm:grid-cols-2 md:grid-cols-3">
        <li class="rounded-lg bg-army-100 p-6">
          <h3 class="text-2xl font-bold pb-2">Bush Trimming</h3>
          <p class="text-lg">
            We shape and maintain your bushes to keep them healthy, tidy, and
            visually appealing.
          </p>
        </li>
        <li class="rounded-lg bg-army-100 p-6">
          <h3 class="text-2xl font-bold pb-2">Mowing</h3>
          <p class="text-lg">
            Our team provides clean, even lawn mowing to keep your grass at the
            perfect height.
          </p>
        </li>
        <li class="rounded-lg bg-army-100 p-6">
          <h3 class="text-2xl font-bold pb-2">Edge Trimming</h3>
          <p class="text-lg">
            We trim along sidewalks, driveways, and flower beds for crisp, clean
            lawn edges.
          </p>
        </li>
        <li class="rounded-lg bg-army-100 p-6">
          <h3 class="text-2xl font-bold pb-2">Rake / Blow</h3>
          <p class="text-lg">
            We remove leaves and lawn clippings using rakes or blowers to keep
            your yard looking fresh.
          </p>
        </li>
        <li class="rounded-lg bg-army-100 p-6">
          <h3 class="text-2xl font-bold pb-2">Irrigation Check</h3>
          <p class="text-lg">
            We inspect your sprinkler system to ensure it's running efficiently
            and covering all zones.
          </p>
        </li>
        <li class="rounded-lg bg-army-100 p-6">
          <h3 class="text-2xl font-bold pb-2">Debris Removal</h3>
          <p class="text-lg">
            We clear out branches, leaves, and other yard debris to keep your
            property neat and safe.
          </p>
        </li>
      </ul>
    </section>

    <Banner cta="Get a landscaping quote today!" />

    <section class="container mx-auto p-4 mb-8">
      <h4 class="py-4 text-3xl font-black uppercase">
        Additional Landscaping Services
      </h4>
      <ul class="grid grid-cols-1 gap-6 sm:grid-cols-2 md:grid-cols-3">
        <li class="rounded-lg bg-army-100 p-6">
          <h3 class="text-2xl font-bold pb-2">Weed Prevention</h3>
          <p class="text-lg">
            We apply treatments and strategies to stop weeds before they take
            root and spread in your yard.
          </p>
        </li>
        <li class="rounded-lg bg-army-100 p-6">
          <h3 class="text-2xl font-bold pb-2">Irrigation</h3>
          <p class="text-lg">
            Installation and maintenance of efficient watering systems to keep
            your lawn and plants healthy while conserving water.
          </p>
        </li>
        <li class="rounded-lg bg-army-100 p-6">
          <h3 class="text-2xl font-bold pb-2">Tree Trimming</h3>
          <p class="text-lg">
            Pruning and shaping of trees to improve appearance, promote healthy
            growth, and prevent potential safety hazards.
          </p>
        </li>
        <li class="rounded-lg bg-army-100 p-6">
          <h3 class="text-2xl font-bold pb-2">Decorative Rock</h3>
          <p class="text-lg">
            Placement of aesthetically pleasing gravel or stone to enhance curb
            appeal and reduce water usage in landscape design.
          </p>
        </li>
        <li class="rounded-lg bg-army-100 p-6">
          <h3 class="text-2xl font-bold pb-2">Boulders</h3>
          <p class="text-lg">
            Strategic placement of large natural rocks to create focal points,
            borders, or accents in your outdoor space.
          </p>
        </li>
        <li class="rounded-lg bg-army-100 p-6">
          <h3 class="text-2xl font-bold pb-2">Clean Ups</h3>
          <p class="text-lg">
            Seasonal or one-time yard clean-up services to remove leaves,
            debris, and overgrowth for a fresh, maintained look.
          </p>
        </li>
        <li class="rounded-lg bg-army-100 p-6">
          <h3 class="text-2xl font-bold pb-2">Junk Removal</h3>
          <p class="text-lg">
            Hauling away unwanted outdoor items, debris, or clutter to keep your
            property clean and usable.
          </p>
        </li>
        <li class="rounded-lg bg-army-100 p-6">
          <h3 class="text-2xl font-bold pb-2">Synthetic Grass</h3>
          <p class="text-lg">
            Professional installation of artificial turf that looks like real
            grass without the upkeep, watering, or mowing.
          </p>
        </li>
        <li class="rounded-lg bg-army-100 p-6">
          <h3 class="text-2xl font-bold pb-2">Pavers</h3>
          <p class="text-lg">
            Custom installation of stone, brick, or concrete pavers for
            walkways, patios, and driveways that add function and style.
          </p>
        </li>
      </ul>
    </section>

    <Banner cta="Ready to transform your landscape?" />
  </main>
</Layout>
